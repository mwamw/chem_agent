APP_ENV=dev
API_V1_PREFIX=/api/v1
PROJECT_NAME=ChemIntel API
DATABASE_URL=postgresql+asyncpg://chemintel:chemintel@127.0.0.1:5433/chemintel
AUTO_CREATE_SCHEMA=false
REDIS_URL=redis://localhost:6379/0
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
JWT_SECRET_KEY=dev-secret-change-before-production-123456
JWT_ALGORITHM=HS256
JWT_ISSUER=chemintel-api
JWT_AUDIENCE=chemintel-api
JWT_EXPIRE_MINUTES=120
JWT_REFRESH_EXPIRE_DAYS=14
DEFAULT_TENANT_ID=tenant_demo
DEMO_AUTH_ENABLED=false
ALLOW_AUTO_USER_SIGNUP=false

EASYAGENT_PATH=/home/wxd/LLM/EasyAgent
LLM_PROVIDER=openai
LLM_MODEL=qwen3.5-9b
LLM_BASE_URL=http://127.0.0.1:5124/v1
LLM_API_KEY=test
LLM_ENABLED=false
LLM_TEMPERATURE=0.1
LLM_TIMEOUT=10

EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BASE_URL=http://127.0.0.1:5124/v1
EMBEDDING_API_KEY=test
EMBEDDING_DIMENSION=384
VECTOR_SEARCH_ENABLED=true

RAG_DEFAULT_K=4
RAG_MULTI_QUERY_COUNT=3
RAG_INITIAL_CANDIDATE_K=8
RAG_PROFILE=balanced
RAG_LLM_QUERY_EXPANSION_ENABLED=false
ALLOWED_ORIGINS=["*"]
