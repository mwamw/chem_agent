APP_ENV=dev
API_V1_PREFIX=/api/v1
PROJECT_NAME=ChemIntel API
DATABASE_URL=postgresql+asyncpg://chemintel:chemintel@127.0.0.1:5433/chemintel
REDIS_URL=redis://localhost:6379/0
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
JWT_SECRET_KEY=change-me
JWT_EXPIRE_MINUTES=120
DEFAULT_TENANT_ID=tenant_demo

EASYAGENT_PATH=/home/wxd/LLM/EasyAgent
LLM_PROVIDER=openai
LLM_MODEL=qwen3.5-9b
LLM_BASE_URL=http://127.0.0.1:5124/v1
LLM_API_KEY=test
LLM_ENABLED=true
LLM_TEMPERATURE=0.1
LLM_TIMEOUT=10

EMBEDDING_PROVIDER=openai
